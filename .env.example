BOT_TOKEN=your_bot_token_here

DB_HOST=localhost
DB_PORT=5432
DB_NAME=sorvancy
DB_USER=sorvancy
DB_PASSWORD=your_password_here

DISCOUNT_PERCENT=10

# ID аккаунта Max Messenger владельца магазина (суперпользователь).
# Если заполнено — init_db.py создаёт запись Staff с is_owner=True при первом запуске.
OWNER_ID=

# Delay between broadcast sends in seconds (default 15)
BROADCAST_SEND_DELAY_SECONDS=15

# Container timezone — bot and scheduler operate in Perm time (UTC+5)
TZ=Asia/Yekaterinburg

# Bot URL for deeplinks embedded in customer QR codes
# Format: https://max.ru/<botName>  (no trailing slash, no ?start=)
# Example: https://max.ru/yourbotname
DEEPLINK_BASE=

# Secret key for HMAC-signed staff invite tokens (any long random string)
INVITE_SECRET=

# Birthday coupon parameters (scenario 19)
BIRTHDAY_COUPON_VALUE=300
BIRTHDAY_COUPON_VALID_DAYS=7
